# Shopify Storefront API (required for checkout and optional for live catalog)
# Get token: Shopify Admin → Settings → Apps → Develop apps → Create app → Configure Storefront API
# Scopes: unauthenticated_read_product_listings, unauthenticated_read_checkouts, unauthenticated_write_checkouts
VITE_SHOPIFY_STORE_DOMAIN=cross-currentprecisionarmory
VITE_SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Analytics and Performance Monitoring Environment Variables
# Google Analytics 4 Configuration
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry Error Tracking Configuration
VITE_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# Analytics Configuration
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_TRACKING=true

# Application Version (for error tracking and releases)
VITE_APP_VERSION=1.0.0

# Development/Testing Flags
# Set to true to enable analytics in development
VITE_ENABLE_ANALYTICS_DEV=false

# Performance Monitoring
# Set to false to disable performance monitoring
VITE_ENABLE_PERFORMANCE_MONITORING=true

# A/B Testing
# Set to false to disable A/B testing
VITE_ENABLE_AB_TESTING=true

# Sample Rates (for production)
# These control what percentage of users/events are tracked
VITE_ANALYTICS_SAMPLE_RATE=1.0
VITE_PERFORMANCE_SAMPLE_RATE=0.1
VITE_ERROR_SAMPLE_RATE=0.1
